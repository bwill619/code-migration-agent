# Copy to .env and fill in values:
#   cp .env.example .env

# --- LLM Provider ---
# Set at least one API key. Used by the refactorer agent (when implemented).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Provider to use: openai | anthropic
LLM_PROVIDER=openai

# Model name for the active provider
LLM_MODEL=gpt-4o

# --- Qdrant Vector Database ---
# Default matches docker-compose.yml local service
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=migration_docs

# --- Pipeline Settings ---
# Max validator retry loops before the graph halts
MAX_ITERATION_COUNT=3
